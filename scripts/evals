#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd -P)"
PROJECT="$ROOT/10x-macos.xcodeproj"
DEFAULT_SUITE="$ROOT/evals/smoke-suite.yml"
DERIVED_DATA="$ROOT/.derivedData/10x-evals"
DEFAULT_BIN="$DERIVED_DATA/Build/Products/Debug/10x-evals"

usage() {
  cat <<EOF
Usage:
  ./scripts/evals list [suite.yml]
  ./scripts/evals build
  ./scripts/evals smoke [--case <id>]
  ./scripts/evals run [suite.yml] [--case <id>]

Environment:
  TENX_EVALS_BIN  Path to an existing 10x-evals binary. Overrides auto-discovery.
EOF
}

die() {
  printf 'error: %s\n' "$*" >&2
  exit 1
}

require_file() {
  local path="$1"
  [[ -f "$path" ]] || die "File not found: $path"
}

has_shared_eval_scheme() {
  xcodebuild -project "$PROJECT" -list 2>/dev/null | grep -Eq '^[[:space:]]+10x-evals$'
}

find_existing_binary() {
  local candidate
  for candidate in \
    "$DEFAULT_BIN" \
    "$ROOT/.build/debug/10x-evals" \
    "$ROOT/build/Build/Products/Debug/10x-evals" \
    "$ROOT/build/Debug/10x-evals"
  do
    if [[ -x "$candidate" ]]; then
      printf '%s\n' "$candidate"
      return 0
    fi
  done

  candidate="$(find "$ROOT/.build" -type f -path '*/debug/10x-evals' -perm -111 2>/dev/null | head -n 1 || true)"
  if [[ -n "$candidate" && -x "$candidate" ]]; then
    printf '%s\n' "$candidate"
    return 0
  fi

  return 1
}

build_binary() {
  if has_shared_eval_scheme; then
    xcodebuild \
      -project "$PROJECT" \
      -scheme 10x-evals \
      -configuration Debug \
      -derivedDataPath "$DERIVED_DATA" \
      build CODE_SIGNING_ALLOWED=NO

    [[ -x "$DEFAULT_BIN" ]] || die "Build completed but the eval binary was not found at $DEFAULT_BIN"
    printf '%s\n' "$DEFAULT_BIN"
    return 0
  fi

  swift build --package-path "$ROOT" --product 10x-evals

  find_existing_binary || die "SwiftPM build completed but the eval binary was not found."
}

resolve_binary() {
  if [[ -n "${TENX_EVALS_BIN:-}" ]]; then
    [[ -x "$TENX_EVALS_BIN" ]] || die "TENX_EVALS_BIN is not executable: $TENX_EVALS_BIN"
    printf '%s\n' "$TENX_EVALS_BIN"
    return 0
  fi

  if find_existing_binary; then
    return 0
  fi

  build_binary
}

list_cases() {
  local suite="${1:-$DEFAULT_SUITE}"
  require_file "$suite"
  grep -E '^  - id:' "$suite" | sed -E 's/^  - id: /- /'
}

run_eval() {
  local suite="$1"
  shift
  require_file "$suite"
  local binary
  binary="$(resolve_binary)"
  exec "$binary" run "$suite" "$@"
}

command="${1:-help}"
if [[ $# -gt 0 ]]; then
  shift
fi

case "$command" in
  help|-h|--help)
    usage
    ;;
  list)
    list_cases "${1:-$DEFAULT_SUITE}"
    ;;
  build)
    resolve_binary
    ;;
  smoke)
    run_eval "$DEFAULT_SUITE" "$@"
    ;;
  run)
    suite="$DEFAULT_SUITE"
    if [[ $# -gt 0 && "$1" != --* ]]; then
      suite="$1"
      shift
    fi
    run_eval "$suite" "$@"
    ;;
  *)
    usage
    die "Unknown command: $command"
    ;;
esac
